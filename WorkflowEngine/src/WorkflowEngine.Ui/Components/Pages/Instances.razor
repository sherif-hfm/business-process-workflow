@page "/instances"
@rendermode InteractiveServer
@inject WorkflowApiClient Api

<PageTitle>Instances</PageTitle>

<h1>Instances</h1>

@if (!string.IsNullOrWhiteSpace(error))
{
    <div class="alert alert-danger">@error</div>
}

<div class="d-flex gap-2 align-items-end mb-3">
    <div>
        <label class="form-label">Status</label>
        <select class="form-select" @bind="status" @bind:after="OnFilterChangedAsync">
            <option value="">All</option>
            <option value="running">Running</option>
            <option value="completed">Completed</option>
            <option value="cancelled">Cancelled</option>
        </select>
    </div>
    <div class="flex-grow-1">
        <label class="form-label">Variables (name:value, comma-separated)</label>
        <input class="form-control" @bind="variableFilter" @bind:after="OnFilterChangedAsync" placeholder="reqno:4711, priority:high" />
    </div>
    <button class="btn btn-outline-primary" @onclick="LoadAsync">Refresh</button>
</div>

@if (result is null)
{
    <p>Loading...</p>
}
else if (result.Items.Count == 0)
{
    <p>No instances found.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Instance</th>
                <th>Workflow</th>
                <th>Current step</th>
                <th>Status</th>
                <th>Claimed by</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var instance in result.Items)
            {
                <tr>
                    <td>#@instance.Id</td>
                    <td>@instance.WorkflowName v@instance.WorkflowVersion</td>
                    <td>@instance.CurrentNodeName</td>
                    <td>@instance.Status</td>
                    <td>@(instance.ClaimedBy ?? "-")</td>
                    <td class="text-end">
                        <a class="btn btn-sm btn-outline-primary" href="@($"instances/{instance.Id}")">Open</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <div class="d-flex align-items-center gap-2">
        <button class="btn btn-outline-secondary btn-sm" disabled="@(page <= 1)" @onclick="PreviousPageAsync">Previous</button>
        <button class="btn btn-outline-secondary btn-sm" disabled="@(!HasNextPage)" @onclick="NextPageAsync">Next</button>
        <span class="text-muted small">Page @result.Page of @TotalPages (@result.TotalCount total)</span>
    </div>
}

@code {
    private PagedResult<InstanceSummaryDto>? result;
    private string? status = "running";
    private string? variableFilter;
    private string? error;
    private int page = 1;
    private const int PageSize = 50;

    private IReadOnlyList<string> ParseVariableFilter() =>
        string.IsNullOrWhiteSpace(variableFilter)
            ? []
            : variableFilter.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);

    private int TotalPages => result is null || result.TotalCount == 0
        ? 1
        : (int)Math.Ceiling(result.TotalCount / (double)result.PageSize);

    private bool HasNextPage => result is not null && page < TotalPages;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task OnFilterChangedAsync()
    {
        page = 1;
        await LoadAsync();
    }

    private async Task PreviousPageAsync()
    {
        if (page <= 1)
        {
            return;
        }

        page--;
        await LoadAsync();
    }

    private async Task NextPageAsync()
    {
        if (!HasNextPage)
        {
            return;
        }

        page++;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        try
        {
            error = null;
            result = await Api.GetInstancesAsync(status, page, PageSize, ParseVariableFilter());
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
    }
}
