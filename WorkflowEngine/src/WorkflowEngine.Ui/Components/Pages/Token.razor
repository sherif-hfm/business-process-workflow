@page "/token"
@rendermode InteractiveServer
@using WorkflowEngine.Ui.Auth
@inject DevTokenFactory TokenFactory
@inject TokenState TokenStore

<PageTitle>Token</PageTitle>

<h1>Test token</h1>
<p class="text-muted">
    Mint a JWT (signed with the shared dev key) to act as a chosen user with chosen roles,
    then all API calls from this UI use it. Development test convenience only.
</p>

@if (!string.IsNullOrWhiteSpace(error))
{
    <div class="alert alert-danger">@error</div>
}

<div class="row">
    <div class="col-md-6">
        <div class="card mb-3">
            <div class="card-body">
                <h2 class="h5">Generate</h2>

                <div class="mb-3">
                    <label class="form-label">User</label>
                    <input class="form-control" @bind="user" placeholder="e.g. alice" />
                </div>

                <div class="mb-2">
                    <label class="form-label">Roles (comma separated)</label>
                    <input class="form-control" @bind="roles" placeholder="e.g. Manager,Finance" />
                </div>
                <div class="mb-3 d-flex flex-wrap gap-1">
                    @foreach (var suggestion in RoleSuggestions)
                    {
                        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="() => AddRole(suggestion)">
                            + @suggestion
                        </button>
                    }
                </div>

                <div class="mb-3">
                    <label class="form-label">Expires in (minutes)</label>
                    <input type="number" class="form-control" style="max-width: 160px" @bind="expiresInMinutes" min="1" />
                </div>

                <button class="btn btn-primary" @onclick="Generate">Generate &amp; apply</button>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card mb-3">
            <div class="card-body">
                <h2 class="h5">Current token</h2>
                @if (TokenStore.HasToken)
                {
                    <p class="mb-1">Identity: <strong>@(TokenStore.CurrentUser ?? "anonymous")</strong></p>
                    <p>Roles: <strong>@(TokenStore.CurrentRoles.Count == 0 ? "(none)" : string.Join(", ", TokenStore.CurrentRoles))</strong></p>
                }
                else
                {
                    <p class="text-muted">No token set. API calls will be unauthenticated (401).</p>
                }

                <label class="form-label">Raw token</label>
                <textarea class="form-control mb-2" rows="6" @bind="rawToken" placeholder="Paste a JWT to use it as-is (useful for negative tests)."></textarea>
                <div class="d-flex gap-2">
                    <button class="btn btn-outline-primary" @onclick="ApplyRaw">Apply pasted token</button>
                    <button class="btn btn-outline-danger" @onclick="Clear">Clear</button>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private static readonly string[] RoleSuggestions = ["Requester", "Manager", "Finance"];

    private string user = "alice";
    private string roles = string.Empty;
    private int expiresInMinutes = 60;
    private string rawToken = string.Empty;
    private string? error;

    protected override void OnInitialized() => rawToken = TokenStore.Token ?? string.Empty;

    private void AddRole(string role)
    {
        var current = roles
            .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .ToList();
        if (!current.Contains(role, StringComparer.OrdinalIgnoreCase))
        {
            current.Add(role);
        }

        roles = string.Join(", ", current);
    }

    private void Generate()
    {
        try
        {
            error = null;
            var roleList = roles
                .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
            var token = TokenFactory.Create(user, roleList, expiresInMinutes);
            TokenStore.Set(token);
            rawToken = token;
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
    }

    private void ApplyRaw()
    {
        error = null;
        TokenStore.Set(rawToken);
    }

    private void Clear()
    {
        error = null;
        TokenStore.Clear();
        rawToken = string.Empty;
    }
}
