@page "/inbox"
@rendermode InteractiveServer
@using WorkflowEngine.Ui.Auth
@inject WorkflowApiClient Api
@inject TokenState Token

<PageTitle>Inbox</PageTitle>

<h1>Inbox</h1>

@if (!string.IsNullOrWhiteSpace(error))
{
    <div class="alert alert-danger">@error</div>
}

@if (!Token.HasToken)
{
    <div class="alert alert-warning">
        No token set. <a href="token">Generate a token</a> to choose an identity and roles.
    </div>
}
else
{
    <div class="d-flex flex-wrap gap-3 align-items-end mb-3">
        <div>
            <div class="text-muted small">Signed in as</div>
            <div><strong>@(Token.CurrentUser ?? "anonymous")</strong>
                <span class="text-muted">
                    (@(Token.CurrentRoles.Count == 0 ? "no roles" : string.Join(", ", Token.CurrentRoles)))
                </span>
            </div>
        </div>
        <button class="btn btn-primary" @onclick="LoadAsync">Refresh</button>
    </div>
}

@if (result is null)
{
    <p>Set a token, then refresh to load your inbox.</p>
}
else if (result.Items.Count == 0)
{
    <p>No inbox items found.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Instance</th>
                <th>Workflow</th>
                <th>Current step</th>
                <th>Step roles</th>
                <th>Claimed by</th>
                <th>Status</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in result.Items)
            {
                <tr>
                    <td>#@item.InstanceId</td>
                    <td>@item.WorkflowName</td>
                    <td>@item.CurrentNodeName</td>
                    <td>@(item.NodeRoles.Count == 0 ? "(any)" : string.Join(", ", item.NodeRoles))</td>
                    <td>@(item.ClaimedBy ?? "-")</td>
                    <td>
                        @if (item.CanAct)
                        {
                            <span class="badge text-bg-success">Ready to act</span>
                        }
                        else if (item.CanClaim)
                        {
                            <span class="badge text-bg-warning">Can claim</span>
                        }
                        else
                        {
                            <span class="badge text-bg-secondary">View only</span>
                        }
                    </td>
                    <td class="text-end">
                        <a class="btn btn-sm btn-outline-primary" href="@($"instances/{item.InstanceId}")">Open</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <div class="d-flex align-items-center gap-2">
        <button class="btn btn-outline-secondary btn-sm" disabled="@(page <= 1)" @onclick="PreviousPageAsync">Previous</button>
        <button class="btn btn-outline-secondary btn-sm" disabled="@(!HasNextPage)" @onclick="NextPageAsync">Next</button>
        <span class="text-muted small">Page @result.Page of @TotalPages (@result.TotalCount total)</span>
    </div>
}

@code {
    private PagedResult<InboxItemDto>? result;
    private string? error;
    private int page = 1;
    private const int PageSize = 50;

    private int TotalPages => result is null || result.TotalCount == 0
        ? 1
        : (int)Math.Ceiling(result.TotalCount / (double)result.PageSize);

    private bool HasNextPage => result is not null && page < TotalPages;

    private async Task PreviousPageAsync()
    {
        if (page <= 1)
        {
            return;
        }

        page--;
        await LoadAsync();
    }

    private async Task NextPageAsync()
    {
        if (!HasNextPage)
        {
            return;
        }

        page++;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        try
        {
            error = null;
            result = null;
            result = await Api.GetInboxAsync(page, PageSize);
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
    }
}
