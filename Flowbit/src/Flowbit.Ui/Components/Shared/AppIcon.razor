<span class="app-icon @Class" aria-hidden="true">
    @switch (Name)
    {
        case "overview":
            <svg viewBox="0 0 24 24"><path d="M4 13h6V4H4v9Zm0 7h6v-5H4v5Zm10 0h6v-9h-6v9Zm0-16v5h6V4h-6Z" /></svg>
            break;
        case "workflows":
            <svg viewBox="0 0 24 24"><path d="M6 3a3 3 0 1 0 0 6 3 3 0 0 0 0-6Zm12 12a3 3 0 1 0 0 6 3 3 0 0 0 0-6ZM6 15a3 3 0 1 0 0 6 3 3 0 0 0 0-6Zm3-9h4a5 5 0 0 1 5 5v4m-9 3h6" /></svg>
            break;
        case "instances":
            <svg viewBox="0 0 24 24"><path d="M4 6h16M4 12h16M4 18h16M7 3v6m10 0V3M7 9v6m10 0V9M7 15v6m10 0v-6" /></svg>
            break;
        case "inbox":
            <svg viewBox="0 0 24 24"><path d="M4 5h16l2 9v5H2v-5l2-9Zm-2 9h5l2 3h6l2-3h5" /></svg>
            break;
        case "assignments":
            <svg viewBox="0 0 24 24"><path d="M4 5h9M4 10h7M4 15h6m7-7a3 3 0 1 0 0-6 3 3 0 0 0 0 6Zm-5 12v-2a4 4 0 0 1 4-4h2a4 4 0 0 1 4 4v2" /></svg>
            break;
        case "token":
            <svg viewBox="0 0 24 24"><path d="M14 7a5 5 0 1 1-9.6 2H2V5h4v2H4.4M9 7h13v4h-3v3h-4v-3h-3" /></svg>
            break;
        case "plus":
            <svg viewBox="0 0 24 24"><path d="M12 5v14M5 12h14" /></svg>
            break;
        case "refresh":
            <svg viewBox="0 0 24 24"><path d="M20 7v5h-5M4 17v-5h5m10.1-3A8 8 0 0 0 5.2 6L4 8m16 8-1.2 2a8 8 0 0 1-13.9-3" /></svg>
            break;
        case "chevron-right":
            <svg viewBox="0 0 24 24"><path d="m9 18 6-6-6-6" /></svg>
            break;
        case "activity":
            <svg viewBox="0 0 24 24"><path d="M3 12h4l2.5-7 5 14 2.5-7h4" /></svg>
            break;
        case "check":
            <svg viewBox="0 0 24 24"><path d="m5 12 4 4L19 6" /></svg>
            break;
        case "alert":
            <svg viewBox="0 0 24 24"><path d="M12 3 2.5 20h19L12 3Zm0 6v5m0 3v.01" /></svg>
            break;
        case "clock":
            <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="9" /><path d="M12 7v5l3 2" /></svg>
            break;
        default:
            <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="8" /></svg>
            break;
    }
</span>

@code {
    [Parameter, EditorRequired] public string Name { get; set; } = string.Empty;
    [Parameter] public string? Class { get; set; }
}
