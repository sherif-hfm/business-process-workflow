@page "/instances/{InstanceId:long}"
@implements IAsyncDisposable
@using System.Text.Json
@using Flowbit.Ui.Auth
@inject WorkflowApiClient Api
@inject NavigationManager Navigation
@inject TokenState Token
@inject IJSRuntime JS

<PageTitle>Instance #@InstanceId · Flowbit</PageTitle>

@if (!string.IsNullOrWhiteSpace(error))
{
    <div class="alert alert-danger" role="alert">@error</div>
}

@if (instance is null)
{
    <PageHeader Eyebrow="Instance" Title="@($"Loading instance #{InstanceId}")" Description="Retrieving process state, actions, variables, and history…" />
    <div class="panel"><div class="skeleton" role="status"></div></div>
}
else
{
    var currentNode = CurrentNode;
    var completedMultiInstanceItems = CompletedMultiInstanceItems;

    <PageHeader Eyebrow="Workflow instance" Title="@($"Instance #{instance.Id}")"
                Description="@($"{instance.Workflow.Name} · Version {instance.Workflow.Version}")">
        <Actions>
            <button class="btn btn-outline-secondary" @onclick="LoadAsync"><AppIcon Name="refresh" /> Refresh</button>
            <a class="btn btn-outline-primary" href="instances">Back to instances</a>
        </Actions>
    </PageHeader>

    <section class="panel mb-3" aria-labelledby="instance-summary-heading">
        <div class="section-heading">
            <div><h2 id="instance-summary-heading">@ExecutionHeading</h2><p>Workflow lifecycle and token positions</p></div>
            <StatusBadge Status="@instance.Status" />
        </div>
        <div class="summary-grid">
            <div class="summary-item"><span>Execution positions</span><strong>@EffectivePositionCount</strong></div>
            @if (!string.IsNullOrWhiteSpace(instance.BusinessKey))
            {
                <div class="summary-item"><span>Business key</span><strong>@instance.BusinessKey · @instance.BusinessKeyUniqueness</strong></div>
            }
            @if (instance.UserTasks is not null)
            {
                <div class="summary-item"><span>Task state</span><strong>@FormatTaskState(instance.UserTasks)</strong></div>
            }
            <div class="summary-item"><span>Started by</span><strong>@(instance.StartedBy ?? "—")</strong></div>
            <div class="summary-item"><span>Created</span><strong>@instance.CreatedAt.ToLocalTime().ToString("g")</strong></div>
            @if (HasMultiInstances)
            {
                <div class="summary-item"><span>Multi-instance</span><strong>@FormatMultiInstanceSummary()</strong></div>
            }
            @if (instance.Completion is not null)
            {
                <div class="summary-item"><span>Completion</span><strong>@CompletionLabel(instance.Completion)</strong></div>
            }
            <div class="summary-item"><span>Acting as</span><strong>@ActingUser · @(Token.CurrentRoles.Count == 0 ? "No roles" : string.Join(", ", Token.CurrentRoles))</strong></div>
        </div>

        <h3 class="h6 mt-3 mb-2">Execution positions</h3>
        <ExecutionPositionList Positions="@instance.ExecutionPositions"
                               LegacyNodeId="@instance.CurrentNodeId"
                               LegacyNodeName="@instance.CurrentNodeName"
                               LegacyNodeExternalId="@instance.CurrentNodeExternalId" />

            @if (instance.Status == "running" && currentNode?.RequiresClaim == true && !HasMultiInstances)
            {
                <div class="d-flex flex-wrap gap-2 mt-3">
                    <button class="btn btn-outline-primary" @onclick="ClaimAsync">Claim as @ActingUser</button>
                    @if (CanUnclaim)
                    {
                        <button class="btn btn-outline-secondary" @onclick="UnclaimAsync">Unclaim</button>
                    }
                </div>
            }

            @if (instance.Status == "running" && CanCancel)
            {
                <button class="btn btn-outline-danger mt-3" @onclick="CancelAsync">Cancel instance</button>
            }
    </section>

    @if (instance.Fault is not null)
    {
        <section class="alert alert-danger mb-3" aria-labelledby="instance-fault-heading">
            <h2 id="instance-fault-heading" class="h5 mb-1">Workflow fault</h2>
            <div><strong>Code:</strong> @(instance.Fault.Code ?? "Legacy / unspecified")</div>
            <div><strong>Description:</strong> @instance.Fault.Description</div>
        </section>
    }
    else if (instance.Completion is { } completion &&
             string.Equals(completion.Kind, WorkflowCompletionKinds.Terminate, StringComparison.OrdinalIgnoreCase))
    {
        <section class="alert alert-success mb-3" aria-labelledby="instance-completion-heading">
            <h2 id="instance-completion-heading" class="h5 mb-1">Instance terminated successfully</h2>
            <div>Triggered by token #@completion.TokenId at @completion.NodeName (#@completion.NodeId) on @completion.CompletedAt.ToLocalTime().ToString("g").</div>
        </section>
    }

    <nav class="status-tabs" aria-label="Instance sections">
        <a class="status-tab active text-decoration-none" href="#actions" @onclick='() => ScrollToSectionAsync("actions")' @onclick:preventDefault>Actions</a>
        @if (instance.ParallelGatewayExecutions.Count > 0) { <a class="status-tab text-decoration-none" href="#parallel-scopes" @onclick='() => ScrollToSectionAsync("parallel-scopes")' @onclick:preventDefault>Parallel scopes</a> }
        @if (HasMultiInstances || completedMultiInstanceItems.Count > 0) { <a class="status-tab text-decoration-none" href="#multi-instance-results" @onclick='() => ScrollToSectionAsync("multi-instance-results")' @onclick:preventDefault>Multi-instance results</a> }
        <a class="status-tab text-decoration-none" href="#variables" @onclick='() => ScrollToSectionAsync("variables")' @onclick:preventDefault>Variables</a>
        <a class="status-tab text-decoration-none" href="#history" @onclick='() => ScrollToSectionAsync("history")' @onclick:preventDefault>History</a>
    </nav>

    @if (instance.ParallelGatewayExecutions.Count > 0)
    {
        <section id="parallel-scopes" class="panel mb-3">
            <div class="section-heading">
                <div><h2>Parallel scopes</h2><p>Fork activations, branch state, and scoped interruption outcomes</p></div>
                <span class="mono-id">@instance.ParallelGatewayExecutions.Count scope@(instance.ParallelGatewayExecutions.Count == 1 ? null : "s")</span>
            </div>
            <div class="table-responsive">
                <table class="table table-sm align-middle">
                    <thead>
                        <tr>
                            <th scope="col">Scope</th>
                            <th scope="col">Fork</th>
                            <th scope="col">Status</th>
                            <th scope="col">Branches</th>
                            <th scope="col">Outcome</th>
                            <th scope="col">Updated</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var scope in instance.ParallelGatewayExecutions.OrderByDescending(item => item.Id))
                        {
                            <tr>
                                <td><span class="mono-id">#@scope.Id</span>@if (scope.ParentExecutionId is long parentId) { <span class="data-subtitle">Parent #@parentId</span> }</td>
                                <td>@ParallelForkLabel(scope.ForkNodeId)</td>
                                <td><StatusBadge Status="@scope.Status" /></td>
                                <td>
                                    @scope.TotalBranchCount total
                                    <span class="data-subtitle">
                                        @scope.ActiveBranchCount active · @scope.CompletedBranchCount completed ·
                                        @scope.MergedBranchCount merged · @scope.InterruptedBranchCount interrupted ·
                                        @scope.CancelledBranchCount cancelled
                                    </span>
                                </td>
                                <td>
                                    @(string.IsNullOrWhiteSpace(scope.CompletionReason) ? "—" : ParallelCompletionReason(scope.CompletionReason))
                                    @if (scope.InterruptingTokenId is long tokenId)
                                    {
                                        <span class="data-subtitle">Token #@tokenId@if (scope.InterruptingNodeId is int nodeId) { <text> · Node #@nodeId</text> }</span>
                                    }
                                </td>
                                <td>@scope.UpdatedAt.ToLocalTime().ToString("g")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </section>
    }

    @if (HasMultiInstances || completedMultiInstanceItems.Count > 0)
    {
        <section id="multi-instance-results" class="panel mb-3">
            <h2 class="h4">Multi-instance result</h2>
            @if (completedMultiInstanceItems.Count == 0)
            {
                <p>No work items completed yet.</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-sm align-middle">
                        <thead>
                            <tr>
                                <th>Execution</th>
                                <th>Item</th>
                                <th>User</th>
                                <th>Action</th>
                                <th>Submitted data</th>
                                <th>When</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in completedMultiInstanceItems)
                            {
                                <tr>
                                    <td>#@item.MultiInstanceExecutionId</td>
                                    <td>@FormatItemNumber(item.ItemIndex)</td>
                                    <td>@(item.PerformedBy ?? "-")</td>
                                    <td>@FlowLabel(item.SequenceFlowId)</td>
                                    <td><code class="text-break">@FormatPayload(item.Payload)</code></td>
                                    <td>@item.PerformedAt.LocalDateTime</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </section>
    }

    @if (HasMultiInstances)
    {
        <div class="alert alert-info">Open a specific work item from the Inbox to claim or take an action.</div>
    }
    @if (interruptFlows.Count > 0)
    {
        <section class="panel mb-3 border-danger">
            <h2 class="h4 text-danger">Interrupt actions</h2>
            <p class="text-muted">These actions apply to the whole multi-instance execution and cancel unfinished work items.</p>
            <div class="row">
                @foreach (var flow in interruptFlows)
                {
                    <div class="col-md-6 mb-3">
                        <div class="card h-100 border-danger">
                            <div class="card-body">
                                <h3 class="h5">@(string.IsNullOrWhiteSpace(flow.Name) ? $"Flow #{flow.Id}" : flow.Name)</h3>
                                <p class="text-muted">Interrupts this execution and moves to node #@flow.TargetRef</p>
                                @foreach (var variable in flow.Variables)
                                {
                                    <div class="mb-2">
                                        <label class="form-label">
                                            @variable.Name
                                            <span class="text-muted">(@variable.DataType@(variable.IsArray ? "[]" : ""))</span>
                                            @if (variable.Required)
                                            {
                                                <span class="text-danger">*</span>
                                            }
                                        </label>
                                        <input class="form-control"
                                               value="@GetFlowInput(flow.Id, variable.Name)"
                                               @oninput="e => SetFlowInput(flow.Id, variable.Name, e.Value?.ToString())" />
                                    </div>
                                }

                                <button class="btn btn-danger"
                                        disabled="@interruptSubmitting"
                                        @onclick="() => TakeInterruptFlowAsync(flow)">
                                    @(interruptSubmitting ? "Submitting..." : "Interrupt and cancel remaining items")
                                </button>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </section>
    }
    <section id="actions" class="panel mb-3">
        <h2 class="h4">Available actions</h2>
        @if (HasAmbiguousActivePositions)
        {
            <div class="alert alert-info mb-0">
                This instance has multiple active branches. Open a linked user task in the execution-position list to act on its exact work item.
            </div>
        }
        else if (HasMultiInstances)
        {
            <p>Personal work-item actions are available from the Inbox.</p>
        }
        else if (IsWaitingForMessage)
        {
            <div class="alert alert-info mb-0">
                Waiting for an authenticated external message. This page refreshes automatically after delivery.
            </div>
        }
        else if (availableFlows.Count == 0)
        {
            <p>No user actions are available.</p>
        }
        else
        {
            <div class="row">
                @foreach (var flow in availableFlows)
                {
                    <div class="col-md-6 mb-3">
                        <div class="card h-100">
                            <div class="card-body">
                                <h3 class="h5">@(string.IsNullOrWhiteSpace(flow.Name) ? $"Flow #{flow.Id}" : flow.Name)</h3>
                                <p class="text-muted">Moves to node #@flow.TargetRef</p>
                                @foreach (var variable in flow.Variables)
                                {
                                    <div class="mb-2">
                                        <label class="form-label">
                                            @variable.Name
                                            <span class="text-muted">(@variable.DataType@(variable.IsArray ? "[]" : ""))</span>
                                            @if (variable.Required)
                                            {
                                                <span class="text-danger">*</span>
                                            }
                                        </label>
                                        <input class="form-control"
                                               value="@GetFlowInput(flow.Id, variable.Name)"
                                               @oninput="e => SetFlowInput(flow.Id, variable.Name, e.Value?.ToString())" />
                                    </div>
                                }

                                <button class="btn btn-primary"
                                        disabled="@(!CanTakeFlow(flow))"
                                        @onclick="() => TakeFlowAsync(flow)">Take action</button>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </section>

    <section id="variables" class="panel mb-3">
        <h2 class="h4">Variables</h2>
        @if (instance.Variables.Count == 0)
        {
            <p>No variables captured.</p>
        }
        else
        {
            <div class="table-responsive"><table class="table table-sm">
                <caption class="visually-hidden">Latest variables stored on instance #@instance.Id</caption>
                <thead>
                    <tr>
                        <th scope="col">Name</th>
                        <th scope="col">Flow</th>
                        <th scope="col">Set by</th>
                        <th scope="col">Value</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var variable in instance.Variables)
                    {
                        <tr>
                            <td>@variable.VariableName</td>
                            <td>@(variable.SourceFlowId?.ToString() ?? "start")</td>
                            <td>@(variable.SetBy ?? "-")</td>
                            <td><code>@FormatJson(variable.Value)</code></td>
                        </tr>
                    }
                </tbody>
            </table></div>
        }
    </section>

    <section id="history" class="panel">
        <h2 class="h4">History</h2>
        @if (instance.History.Count == 0)
        {
            <p>No transitions yet.</p>
        }
        else
        {
            <div class="table-responsive"><table class="table table-sm">
                <caption class="visually-hidden">Transition history for instance #@instance.Id</caption>
                <thead>
                    <tr>
                        <th scope="col">When</th>
                        <th scope="col">Token</th>
                        <th scope="col">From</th>
                        <th scope="col">To</th>
                        <th scope="col">Flow</th>
                        <th scope="col">Actor</th>
                        <th scope="col">Details</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in instance.History)
                    {
                        <tr>
                            <td>@item.PerformedAt.LocalDateTime</td>
                            <td>@(item.TokenId is long tokenId ? $"#{tokenId}" : "—")</td>
                            <td>#@item.FromNodeId</td>
                            <td>#@item.ToNodeId</td>
                            <td>@(item.SequenceFlowId?.ToString() ?? "-")</td>
                            <td>@(item.PerformedBy ?? "-")</td>
                            <td>@HistoryDetails(item)</td>
                        </tr>
                    }
                </tbody>
            </table></div>
        }
    </section>
}

@code {
    [Parameter]
    public long InstanceId { get; set; }

    private InstanceDetailDto? instance;
    private IReadOnlyList<SequenceFlowModel> availableFlows = [];
    private IReadOnlyList<SequenceFlowModel> interruptFlows = [];
    private readonly Dictionary<string, string?> flowInputs = [];
    private readonly SemaphoreSlim refreshGate = new(1, 1);
    private readonly CancellationTokenSource pollCancellation = new();
    private Task? pollTask;
    private string? error;
    private bool interruptSubmitting;

    private string ActingUser => NormalizeUser(Token.CurrentUser);

    private ValueTask ScrollToSectionAsync(string sectionId) =>
        JS.InvokeVoidAsync("flowbit.scrollToSection", sectionId);

    // Instance DTOs intentionally do not own a claim. For the legacy
    // instance-addressed controls, the grouped work summary identifies the
    // claimant only when the current active task is unambiguous.
    private string? CurrentClaimedBy => instance?.UserTasks?.SoleClaimedBy;

    private IReadOnlyList<ExecutionPositionDto> ExecutionPositions =>
        instance?.ExecutionPositions ?? [];

    private IReadOnlyList<ExecutionPositionDto> ActivePositions =>
        ExecutionPositions
            .Where(position => string.Equals(
                position.TokenStatus, "active", StringComparison.OrdinalIgnoreCase))
            .OrderBy(position => position.TokenId)
            .ToList();

    private IReadOnlyList<MultiInstanceProgressDto> MultiInstanceExecutions
    {
        get
        {
            if (instance is null) return [];
            if (instance.MultiInstances.Count > 0) return instance.MultiInstances;
            return instance.MultiInstance is null ? [] : [instance.MultiInstance];
        }
    }

    private MultiInstanceProgressDto? SoleActiveMultiInstance
    {
        get
        {
            var active = MultiInstanceExecutions
                .Where(progress => string.Equals(
                    progress.Status, "active", StringComparison.OrdinalIgnoreCase))
                .ToList();
            return active.Count == 1 ? active[0] : null;
        }
    }

    private bool HasMultiInstances => MultiInstanceExecutions.Count > 0;
    private bool HasAmbiguousActivePositions => ActivePositions.Count > 1;
    private bool CanUseLegacyInstanceActions =>
        ExecutionPositions.Count == 0 || ActivePositions.Count == 1;
    private int EffectivePositionCount =>
        ExecutionPositions.Count > 0 ? ExecutionPositions.Count : 1;

    private string ExecutionHeading
    {
        get
        {
            if (ActivePositions.Count > 1)
            {
                return $"{ActivePositions.Count} active execution positions";
            }
            if (ActivePositions.Count == 1)
            {
                return ActivePositions[0].NodeName;
            }
            if (instance?.Completion is { } completion)
            {
                return string.Equals(
                    completion.Kind, WorkflowCompletionKinds.Terminate,
                    StringComparison.OrdinalIgnoreCase)
                    ? $"Terminated at {completion.NodeName}"
                    : $"Completed at {completion.NodeName}";
            }
            if (ExecutionPositions.Count == 1)
            {
                return ExecutionPositions[0].NodeName;
            }
            return instance?.CurrentNodeName ?? "Execution positions";
        }
    }

    private FlowNodeModel? CurrentNode
    {
        get
        {
            if (instance is null) return null;
            var nodeId = ExecutionPositions.Count == 0
                ? instance.CurrentNodeId
                : ActivePositions.Count == 1 ? ActivePositions[0].NodeId : (int?)null;
            return nodeId is null
                ? null
                : instance.Workflow.Definition.FlowNodes.SingleOrDefault(node => node.Id == nodeId);
        }
    }

    private bool IsWaitingForMessage =>
        instance?.Status == "running"
        && (ExecutionPositions.Count > 0
            ? ActivePositions.Any(position =>
                BpmnFlowNodeTypes.IsMessageCatch(position.NodeType))
            : CurrentNode is { } node && BpmnFlowNodeTypes.IsMessageCatch(node.Type));

    private IReadOnlyList<InstanceHistoryDto> CompletedMultiInstanceItems =>
        instance?.History
            .Where(item => item.MultiInstanceExecutionId is not null
                           && item.UserTaskId is not null
                           && item.SequenceFlowId is not null
                           && IsCompletedMultiInstanceItem(item.Note))
            .OrderByDescending(item => item.PerformedAt)
            .ThenByDescending(item => item.Id)
            .ToList()
        ?? [];

    private bool CanTakeFlow(SequenceFlowModel flow)
    {
        if (instance is null || instance.Status != "running")
        {
            return false;
        }

        var node = CurrentNode;
        if (node is null || !BpmnFlowNodeTypes.IsUserTask(node.Type))
        {
            return false;
        }

        // Available flows are already filtered by task/flow roles, stored-state
        // conditions, claim ownership, and role-scoped claim bypasses. The POST
        // action repeats these checks to protect against stale page state.
        return availableFlows.Any(candidate => candidate.Id == flow.Id);
    }

    private bool CanUnclaim
    {
        get
        {
            if (instance is null) return false;
            if (string.IsNullOrWhiteSpace(CurrentClaimedBy)) return false;

            var normalizedUser = ActingUser;
            if (string.Equals(CurrentClaimedBy, normalizedUser, StringComparison.OrdinalIgnoreCase))
            {
                return true;
            }

            var unclaimRoles = instance.Workflow?.Definition?.UnclaimRoles ?? [];
            if (unclaimRoles.Count > 0)
            {
                var actorRoles = Token.CurrentRoles ?? [];
                return unclaimRoles.Any(r => actorRoles.Contains(r, StringComparer.OrdinalIgnoreCase));
            }

            return false;
        }
    }

    private bool CanCancel
    {
        get
        {
            if (instance is null) return false;

            var cancelRoles = instance.Workflow?.Definition?.CancelRoles ?? [];
            if (cancelRoles.Count == 0)
            {
                return true;
            }

            var actorRoles = Token.CurrentRoles ?? [];
            return cancelRoles.Any(r => actorRoles.Contains(r, StringComparer.OrdinalIgnoreCase));
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
        pollTask = PollAsync(pollCancellation.Token);
    }

    private static string FormatTaskState(UserTaskWorkSummaryDto tasks)
    {
        if (tasks.ActiveCount == 1 && tasks.PendingCount == 0)
        {
            if (!string.IsNullOrWhiteSpace(tasks.SoleAssignee))
            {
                return $"Assigned to {tasks.SoleAssignee}";
            }
            if (!string.IsNullOrWhiteSpace(tasks.SoleClaimedBy))
            {
                return $"Claimed by {tasks.SoleClaimedBy}";
            }
            if (!tasks.IsMultiInstance)
            {
                return "Unclaimed";
            }
        }

        var parts = new List<string> { $"{tasks.ActiveCount} active" };
        if (tasks.PendingCount > 0) parts.Add($"{tasks.PendingCount} pending");
        if (tasks.ClaimedCount > 0) parts.Add($"{tasks.ClaimedCount} claimed");
        if (tasks.AssignedCount > 0) parts.Add($"{tasks.AssignedCount} assigned");
        return string.Join(", ", parts);
    }

    private string FormatMultiInstanceSummary()
    {
        if (MultiInstanceExecutions.Count == 1)
        {
            var progress = MultiInstanceExecutions[0];
            return $"{progress.Completed} / {progress.Total} completed · {progress.Active} active";
        }

        return $"{MultiInstanceExecutions.Count} executions · " +
               $"{MultiInstanceExecutions.Sum(progress => progress.Active)} active · " +
               $"{MultiInstanceExecutions.Sum(progress => progress.Completed)} completed";
    }

    private static string CompletionLabel(CompletionInfoDto completion)
    {
        var kind = string.Equals(
            completion.Kind, WorkflowCompletionKinds.Terminate,
            StringComparison.OrdinalIgnoreCase)
            ? "Terminated successfully"
            : "Completed normally";
        return $"{kind} at {completion.NodeName} · {completion.CompletedAt.ToLocalTime():g}";
    }

    private string ParallelForkLabel(int nodeId)
    {
        var node = instance?.Workflow.Definition.FlowNodes
            .SingleOrDefault(candidate => candidate.Id == nodeId);
        return node is null ? $"Node #{nodeId}" : $"{node.Name} (#{nodeId})";
    }

    private static string ParallelCompletionReason(string reason) => reason switch
    {
        "join" => "Joined",
        "interrupt" or "parallelInterrupt" => "Scoped interrupt",
        "terminateEnd" => "Terminate end",
        "errorEnd" => "Workflow fault",
        "instanceCancelled" => "Instance cancellation",
        "allEnded" => "All branches ended",
        _ => reason
    };

    private static string HistoryDetails(InstanceHistoryDto item)
    {
        if (item.Note is "parallelFork")
        {
            return item.TokenId is long tokenId
                ? $"Parallel branch forked for token #{tokenId}"
                : "Parallel branch forked";
        }
        if (item.Note is "parallelJoin")
        {
            return item.TokenId is long tokenId
                ? $"Parallel join released token #{tokenId}"
                : "Parallel join released";
        }
        if (item.Note is "parallelInterrupt")
        {
            return item.TokenId is long tokenId
                ? $"Parallel scope interrupted by token #{tokenId}; active sibling work was cancelled"
                : "Parallel scope interrupted; active sibling work was cancelled";
        }
        if (item.Note is "parallelInterruptSkipped")
        {
            return "No matching active parallel scope remained; continuation ran without cancellation";
        }
        if (item.Note is "parallelScopeCancelled")
        {
            return "Token cancelled by a scoped parallel interrupt";
        }
        if (item.Note is "terminateEnd")
        {
            return item.TokenId is long tokenId
                ? $"Terminate end completed the instance from token #{tokenId}"
                : "Terminate end completed the instance";
        }
        if (!string.Equals(item.Note, "taskAssignment", StringComparison.Ordinal))
        {
            return item.Note ?? "-";
        }

        var operation = HistoryPayloadString(item, "operation") ?? "assignment";
        var previous = HistoryPayloadString(item, "previousOwner") ?? "shared pool";
        var current = HistoryPayloadString(item, "newOwner") ?? "shared pool";
        var reason = HistoryPayloadString(item, "reason");
        var summary = operation switch
        {
            UserTaskAssignmentOperations.Assigned => $"Assigned to {current}",
            UserTaskAssignmentOperations.Reassigned => $"Reassigned from {previous} to {current}",
            UserTaskAssignmentOperations.Unassigned => $"Released {previous} to the shared pool",
            _ => $"Assignment changed from {previous} to {current}"
        };
        return string.IsNullOrWhiteSpace(reason) ? summary : $"{summary} — {reason}";
    }

    private static string? HistoryPayloadString(InstanceHistoryDto item, string name)
    {
        if (item.Payload is null || !item.Payload.TryGetValue(name, out var value)
                                 || value.ValueKind is JsonValueKind.Null or JsonValueKind.Undefined)
        {
            return null;
        }
        return value.ValueKind == JsonValueKind.String ? value.GetString() : value.GetRawText();
    }

    private async Task LoadAsync()
    {
        await refreshGate.WaitAsync();
        try
        {
            error = null;
            await RefreshInstanceStateAsync();
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            refreshGate.Release();
        }
    }

    private async Task ClaimAsync() => await RefreshFrom(async () =>
        instance = await Api.ClaimAsync(InstanceId));

    private async Task UnclaimAsync() => await RefreshFrom(async () =>
        instance = await Api.UnclaimAsync(InstanceId));

    private async Task CancelAsync()
    {
        var confirmed = await JS.InvokeAsync<bool>(
            "confirm",
            $"Cancel instance #{InstanceId}? Open tasks will be cancelled and this cannot be resumed.");
        if (!confirmed)
        {
            return;
        }

        await RefreshFrom(async () =>
        {
            await Api.CancelAsync(InstanceId);
            Navigation.NavigateTo("/instances");
        });
    }

    private async Task TakeFlowAsync(SequenceFlowModel flow)
    {
        await RefreshFrom(async () =>
        {
            var variables = BuildPayload(flow);
            instance = await Api.TakeFlowAsync(
                InstanceId,
                flow.Id,
                new TakeFlowRequest(variables));
        });
    }

    private async Task TakeInterruptFlowAsync(SequenceFlowModel flow)
    {
        var executionId = SoleActiveMultiInstance?.ExecutionId;
        if (executionId is null || interruptSubmitting)
        {
            return;
        }

        var flowName = string.IsNullOrWhiteSpace(flow.Name) ? $"flow #{flow.Id}" : flow.Name;
        var confirmed = await JS.InvokeAsync<bool>(
            "confirm",
            $"Take '{flowName}' and cancel every unfinished work item?");
        if (!confirmed)
        {
            return;
        }

        await refreshGate.WaitAsync();
        try
        {
            interruptSubmitting = true;
            error = null;
            var variables = BuildPayload(flow);
            instance = await Api.TakeMultiInstanceInterruptFlowAsync(
                executionId.Value,
                flow.Id,
                new TakeFlowRequest(variables));
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            interruptSubmitting = false;
            try
            {
                await RefreshInstanceStateAsync();
            }
            catch (Exception ex)
            {
                error ??= ex.Message;
            }
            refreshGate.Release();
        }
    }

    private async Task PollAsync(CancellationToken cancellationToken)
    {
        try
        {
            using var timer = new PeriodicTimer(TimeSpan.FromSeconds(5));
            while (await timer.WaitForNextTickAsync(cancellationToken))
            {
                if (SoleActiveMultiInstance is null
                    && !IsWaitingForMessage
                    && ActivePositions.Count <= 1)
                {
                    continue;
                }

                if (!await refreshGate.WaitAsync(0, cancellationToken))
                {
                    continue;
                }

                try
                {
                    await InvokeAsync(async () =>
                    {
                        try
                        {
                            await RefreshInstanceStateAsync(cancellationToken);
                            StateHasChanged();
                        }
                        catch
                        {
                            // Keep the last successful state and retry on the next tick.
                        }
                    });
                }
                finally
                {
                    refreshGate.Release();
                }
            }
        }
        catch (OperationCanceledException) when (cancellationToken.IsCancellationRequested)
        {
        }
    }

    private async Task RefreshInstanceStateAsync(CancellationToken cancellationToken = default)
    {
        var refreshed = await Api.GetInstanceAsync(InstanceId, cancellationToken);
        if (refreshed is not null)
        {
            instance = refreshed;
        }
        await LoadAvailableActionsAsync(cancellationToken);
    }

    private async Task LoadAvailableActionsAsync(CancellationToken cancellationToken = default)
    {
        availableFlows = instance is null || HasMultiInstances || !CanUseLegacyInstanceActions
            ? []
            : await Api.GetAvailableFlowsAsync(InstanceId, cancellationToken);
        interruptFlows = SoleActiveMultiInstance is { } progress
            ? await Api.GetMultiInstanceInterruptFlowsAsync(progress.ExecutionId, cancellationToken)
            : [];
    }

    private async Task RefreshFrom(Func<Task> action)
    {
        await refreshGate.WaitAsync();
        try
        {
            error = null;
            await action();
            instance ??= await Api.GetInstanceAsync(InstanceId);
            await LoadAvailableActionsAsync();
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            refreshGate.Release();
        }
    }

    private string? GetFlowInput(int flowId, string variableName) =>
        flowInputs.TryGetValue(Key(flowId, variableName), out var value) ? value : null;

    private void SetFlowInput(int flowId, string variableName, string? value) =>
        flowInputs[Key(flowId, variableName)] = value;

    private Dictionary<string, JsonElement> BuildPayload(SequenceFlowModel flow)
    {
        var payload = new Dictionary<string, JsonElement>();
        foreach (var variable in flow.Variables)
        {
            var raw = GetFlowInput(flow.Id, variable.Name);
            if (string.IsNullOrWhiteSpace(raw))
            {
                continue;
            }

            payload[variable.Name] = ToJsonElement(variable, raw);
        }

        return payload;
    }

    private static string Key(int flowId, string variableName) => $"{flowId}:{variableName}";

    private static string NormalizeUser(string? user) =>
        string.IsNullOrWhiteSpace(user) ? "anonymous" : user.Trim();

    private string FlowLabel(int? flowId)
    {
        if (flowId is null)
        {
            return "-";
        }

        var flow = instance?.Workflow.Definition.SequenceFlows.SingleOrDefault(candidate => candidate.Id == flowId.Value);
        return string.IsNullOrWhiteSpace(flow?.Name)
            ? $"Flow #{flowId.Value}"
            : $"{flow.Name} (#{flowId.Value})";
    }

    private static bool IsCompletedMultiInstanceItem(string? note) =>
        note is "multiInstanceItem" or "multiInstanceComplete" or "multiInstanceInterrupt";

    private static string FormatItemNumber(int? itemIndex) =>
        itemIndex is null ? "-" : (itemIndex.Value + 1).ToString();

    private static string FormatPayload(Dictionary<string, JsonElement>? payload) =>
        payload is null || payload.Count == 0 ? "-" : JsonSerializer.Serialize(payload);

    private static string FormatJson(JsonElement element) =>
        element.ValueKind == JsonValueKind.String ? element.GetString() ?? string.Empty : element.GetRawText();

    public async ValueTask DisposeAsync()
    {
        pollCancellation.Cancel();
        if (pollTask is not null)
        {
            try
            {
                await pollTask;
            }
            catch (OperationCanceledException)
            {
            }
        }
        pollCancellation.Dispose();
    }

    private static JsonElement ToJsonElement(VariableModel variable, string raw)
    {
        if (variable.IsArray)
        {
            var values = raw.Split(',', StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries);
            return JsonSerializer.SerializeToElement(values);
        }

        return variable.DataType switch
        {
            WorkflowVariableTypes.Number when decimal.TryParse(raw, out var number) => JsonSerializer.SerializeToElement(number),
            WorkflowVariableTypes.Boolean when bool.TryParse(raw, out var boolean) => JsonSerializer.SerializeToElement(boolean),
            _ => JsonSerializer.SerializeToElement(raw)
        };
    }
}
