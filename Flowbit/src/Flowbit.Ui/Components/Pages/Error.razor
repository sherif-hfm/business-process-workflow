@page "/Error"
@using System.Diagnostics

<PageTitle>Error · Flowbit</PageTitle>

<PageHeader Eyebrow="System" Title="Something went wrong" Description="Flowbit could not complete this request." />
<section class="panel">
    <EmptyState Icon="alert" Title="The request failed" Description="Return to the overview and try again. If the problem continues, use the request ID when checking the application logs.">
        @if (ShowRequestId) { <div class="mb-3"><span class="data-subtitle">Request ID</span><code>@RequestId</code></div> }
        <a class="btn btn-primary" href="">Return to overview</a>
    </EmptyState>
</section>

@code{
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized() =>
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
}
