@page "/workflows"
@using System.Text
@using System.Text.Json
@inject WorkflowApiClient Api
@inject IJSRuntime JS

<PageTitle>Workflows · Flowbit</PageTitle>

<PageHeader Eyebrow="Manage" Title="Workflow definitions"
            Description="Import editor JSON, control published versions, and start new process instances.">
    <Actions>
        <button class="btn btn-outline-secondary" @onclick="LoadAsync"><AppIcon Name="refresh" /> Refresh</button>
        <a class="btn btn-primary" href="#import-workflow"><AppIcon Name="plus" /> Import definition</a>
    </Actions>
</PageHeader>

@if (!string.IsNullOrWhiteSpace(error))
{
    <div class="alert alert-danger" role="alert">@error</div>
}

<section id="import-workflow" class="panel mb-3" aria-labelledby="import-workflow-heading">
    <div class="section-heading">
        <div><h2 id="import-workflow-heading">Import editor JSON</h2><p>Select a workflow exported by <code>flowbit-editor.html</code>. Files are limited to 2 MB.</p></div>
    </div>
    <label class="form-label" for="workflow-json-file">Workflow definition file</label>
    <InputFile id="workflow-json-file" @key="inputFileKey" OnChange="OnInputFileChange" class="form-control" accept=".json,application/json" />
    @if (!string.IsNullOrWhiteSpace(workflowJson))
    {
        <div class="summary-grid my-3">
            <div class="summary-item"><span>File</span><strong>@fileName</strong></div>
            <div class="summary-item"><span>Size</span><strong>@(fileSize.HasValue ? $"{fileSize.Value:N0} bytes" : "Unknown")</strong></div>
        </div>
        <details class="mb-3"><summary class="section-link">Preview JSON</summary><pre class="bg-light p-3 mt-2 border rounded font-monospace overflow-auto" style="max-height: 220px; white-space: pre-wrap; overflow-wrap: anywhere;">@workflowJson</pre></details>
    }
    <div class="d-flex flex-wrap align-items-center gap-3 mt-3">
        <button class="btn btn-primary" @onclick="ImportAsync" disabled="@(string.IsNullOrWhiteSpace(workflowJson) || importing)">
            @(importing ? "Importing…" : publishOnImport ? "Import and publish" : "Import definition")
        </button>
        <div class="form-check">
            <input type="checkbox" class="form-check-input" id="publishOnImport" @bind="publishOnImport" />
            <label class="form-check-label" for="publishOnImport">Publish on import</label>
        </div>
    </div>
</section>

<section aria-labelledby="definitions-heading">
    <div class="section-heading">
        <div><h2 id="definitions-heading">Definitions</h2><p>@(workflows is null ? "Loading workflow families…" : $"{workflows.Count:N0} workflow families")</p></div>
    </div>
    @if (workflows is null)
    {
        <div class="loading-grid" role="status"><div class="skeleton"></div><div class="skeleton"></div></div>
    }
    else if (workflows.Count == 0)
    {
        <div class="panel"><EmptyState Icon="workflows" Title="No workflow definitions" Description="Import a JSON definition from the Flowbit editor to get started." /></div>
    }
    else
    {
        <div class="accordion" id="workflowAccordion">
            @foreach (var workflow in workflows)
            {
                var isExpanded = expandedKeys.Contains(workflow.WorkflowKey);
                <div class="accordion-item">
                    <h2 class="accordion-header">
                        <button class="accordion-button @(isExpanded ? "" : "collapsed")" type="button"
                                aria-expanded="@(isExpanded ? "true" : "false")" @onclick="() => ToggleExpand(workflow.WorkflowKey)">
                            <span class="me-auto"><strong>@workflow.Name</strong><span class="data-subtitle">@workflow.WorkflowKey · Version @workflow.Version</span></span>
                            @if (workflow.IsDefault)
                            {
                                <StatusBadge Status="default" Text="Default" />
                            }
                            <StatusBadge Status="@(workflow.IsPublished ? "published" : "unpublished")" />
                        </button>
                    </h2>
                    @if (isExpanded)
                    {
                        <div class="accordion-body">
                            @if (loadingKeys.Contains(workflow.WorkflowKey))
                            {
                                <div role="status" class="text-muted">Loading versions…</div>
                            }
                            else if (!versionsByKey.TryGetValue(workflow.WorkflowKey, out var rows) || rows.Count == 0)
                            {
                                <p class="text-muted">No versions found.</p>
                            }
                            else
                            {
                                <div class="table-responsive"><table class="table table-sm align-middle">
                                    <caption class="visually-hidden">Versions of @workflow.Name</caption>
                                    <thead>
                                        <tr>
                                            <th scope="col">Version</th>
                                            <th scope="col">Publication</th>
                                            <th scope="col">Default</th>
                                            <th scope="col">Created</th>
                                            <th scope="col" class="text-end">Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var v in rows)
                                        {
                                            <tr>
                                                <td>v@(v.Version)</td>
                                                <td>
                                                    @if (v.IsPublished)
                                                    {
                                                        <StatusBadge Status="published" />
                                                    }
                                                    else
                                                    {
                                                        <StatusBadge Status="unpublished" />
                                                    }
                                                </td>
                                                <td>
                                                    @if (v.IsDefault)
                                                    {
                                                        <StatusBadge Status="default" Text="Default" />
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted">—</span>
                                                    }
                                                </td>
                                                <td class="small text-muted">@v.CreatedAt.ToLocalTime().ToString("g")</td>
                                                <td><div class="d-flex flex-wrap justify-content-end gap-1">
                                                    @if (v.IsPublished)
                                                    {
                                                        <a class="btn btn-sm btn-outline-primary" href="@($"workflows/{v.Id}/start")">Start</a>
                                                    }
                                                    @if (v.IsPublished)
                                                    {
                                                        <button class="btn btn-sm btn-outline-secondary" disabled="@busyIds.Contains(v.Id)" @onclick="() => UnpublishAsync(v.Id)">Unpublish</button>
                                                    }
                                                    else
                                                    {
                                                        <button class="btn btn-sm btn-outline-primary" disabled="@busyIds.Contains(v.Id)" @onclick="() => PublishAsync(v.Id)">Publish</button>
                                                    }
                                                    @if (!v.IsDefault)
                                                    {
                                                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => SetDefaultAsync(v.Id)" disabled="@(!v.IsPublished || busyIds.Contains(v.Id))">Set default</button>
                                                    }
                                                    <button class="btn btn-sm btn-outline-secondary" disabled="@busyIds.Contains(v.Id)" @onclick="() => DownloadAsync(v.Id)">Download JSON</button>
                                                    <button class="btn btn-sm btn-outline-danger" disabled="@busyIds.Contains(v.Id)" @onclick="() => DeleteAsync(v.Id)">Delete</button>
                                                </div></td>
                                            </tr>
                                        }
                                    </tbody>
                                </table></div>
                            }
                        </div>
                    }
                </div>
            }
        </div>
    }
</section>

@code {
    private static readonly JsonSerializerOptions JsonOptions = new(JsonSerializerDefaults.Web)
    {
        PropertyNameCaseInsensitive = true,
        WriteIndented = true
    };

    private IReadOnlyList<WorkflowSummaryDto>? workflows;
    private Dictionary<string, IReadOnlyList<WorkflowSummaryDto>> versionsByKey = new();
    private HashSet<string> expandedKeys = new();
    private HashSet<string> loadingKeys = new();
    private HashSet<long> busyIds = new();
    private string? workflowJson;
    private string? error;
    private string? fileName;
    private long? fileSize;
    private object inputFileKey = new();
    private bool publishOnImport = true;
    private bool importing;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        try
        {
            error = null;
            workflows = await Api.GetWorkflowsAsync();
        }
        catch (Exception ex)
        {
            error = ex.Message;
            workflows = [];
        }
    }

    private async Task ToggleExpand(string workflowKey)
    {
        if (expandedKeys.Contains(workflowKey))
        {
            expandedKeys.Remove(workflowKey);
        }
        else
        {
            expandedKeys.Add(workflowKey);
            await LoadVersionsAsync(workflowKey);
        }
    }

    private async Task LoadVersionsAsync(string workflowKey)
    {
        try
        {
            loadingKeys.Add(workflowKey);
            error = null;
            var rows = await Api.GetWorkflowVersionsAsync(workflowKey);
            versionsByKey[workflowKey] = rows;
        }
        catch (Exception ex)
        {
            error = ex.Message;
            versionsByKey[workflowKey] = [];
        }
        finally
        {
            loadingKeys.Remove(workflowKey);
        }
    }

    private async Task OnInputFileChange(InputFileChangeEventArgs e)
    {
        try
        {
            error = null;
            var file = e.File;
            fileName = file.Name;
            fileSize = file.Size;

            // Restrict file size to 2MB (2 * 1024 * 1024 bytes)
            using var stream = file.OpenReadStream(maxAllowedSize: 2 * 1024 * 1024);
            using var reader = new StreamReader(stream);
            workflowJson = await reader.ReadToEndAsync();
        }
        catch (Exception ex)
        {
            error = $"Failed to read file: {ex.Message}";
            workflowJson = null;
            fileName = null;
            fileSize = null;
        }
    }

    private async Task ImportAsync()
    {
        try
        {
            importing = true;
            error = null;
            var definition = JsonSerializer.Deserialize<WorkflowModel>(workflowJson ?? string.Empty, JsonOptions)
                ?? throw new InvalidOperationException("Workflow JSON could not be parsed.");
            await Api.CreateWorkflowAsync(new CreateWorkflowRequest(definition, Publish: publishOnImport));
            workflowJson = null;
            fileName = null;
            fileSize = null;
            inputFileKey = new object(); // Resets the InputFile component
            await ReloadVersionsAsync();
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            importing = false;
        }
    }

    private Task PublishAsync(long id) => RunVersionActionAsync(id, () => Api.PublishWorkflowAsync(id));

    private async Task UnpublishAsync(long id)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", "Unpublish this workflow version? New instances will no longer be able to start from it.");
        if (confirmed)
        {
            await RunVersionActionAsync(id, () => Api.UnpublishWorkflowAsync(id));
        }
    }

    private Task SetDefaultAsync(long id) => RunVersionActionAsync(id, () => Api.SetDefaultWorkflowAsync(id));

    private async Task DownloadAsync(long id)
    {
        try
        {
            busyIds.Add(id);
            error = null;

            var workflow = await Api.GetWorkflowAsync(id)
                ?? throw new InvalidOperationException("Workflow version was not found.");
            var json = JsonSerializer.Serialize(workflow.Definition, JsonOptions);
            await using var stream = new MemoryStream(Encoding.UTF8.GetBytes(json));
            using var streamReference = new DotNetStreamReference(stream);

            await JS.InvokeVoidAsync(
                "flowbit.downloadFileFromStream",
                DownloadFileName(workflow),
                streamReference);
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            busyIds.Remove(id);
        }
    }

    private static string DownloadFileName(WorkflowDetailDto workflow)
    {
        var safeKey = string.Concat(workflow.WorkflowKey.Select(character =>
            char.IsLetterOrDigit(character) || character is '-' or '_' or '.' ? character : '-'))
            .Trim('-', '.');

        return $"{(string.IsNullOrWhiteSpace(safeKey) ? "workflow" : safeKey)}-v{workflow.Version}.json";
    }

    private async Task DeleteAsync(long id)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", "Delete this workflow version? This cannot be undone.");
        if (confirmed)
        {
            await RunVersionActionAsync(id, () => Api.DeleteWorkflowAsync(id));
        }
    }

    private async Task RunVersionActionAsync(long id, Func<Task> action)
    {
        try
        {
            busyIds.Add(id);
            error = null;
            await action();
            await ReloadVersionsAsync();
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            busyIds.Remove(id);
        }
    }

    private async Task ReloadVersionsAsync()
    {
        await LoadAsync();
        foreach (var key in expandedKeys.ToList())
        {
            await LoadVersionsAsync(key);
        }
    }
}
