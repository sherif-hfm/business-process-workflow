@page "/workflows"
@rendermode InteractiveServer
@using System.Text.Json
@inject WorkflowApiClient Api

<PageTitle>Workflow Definitions</PageTitle>

<h1>Workflow Definitions</h1>

@if (!string.IsNullOrWhiteSpace(error))
{
    <div class="alert alert-danger">@error</div>
}

<section class="mb-4">
    <h2 class="h4">Import editor JSON</h2>
    <p class="text-muted">Select the JSON file exported by <code>flowbit-editor.html</code> to import it.</p>
    <div class="mb-3">
        <InputFile @key="inputFileKey" OnChange="OnInputFileChange" class="form-control" accept=".json" />
    </div>
    @if (!string.IsNullOrWhiteSpace(workflowJson))
    {
        <div class="card mb-3 bg-light text-dark">
            <div class="card-body">
                <h5 class="card-title h6">Loaded File Details</h5>
                <p class="card-text mb-1 small"><strong>Name:</strong> @fileName</p>
                <p class="card-text mb-2 small"><strong>Size:</strong> @(fileSize.HasValue ? $"{fileSize.Value:N0} bytes" : "Unknown")</p>
                <details>
                    <summary class="text-primary small" style="cursor: pointer;">View JSON Preview</summary>
                    <pre class="bg-white p-2 mt-2 border rounded font-monospace" style="max-height: 200px; overflow-y: auto; font-size: 0.8em; white-space: pre-wrap; word-break: break-all;">@workflowJson</pre>
                </details>
            </div>
        </div>
    }
    <div class="d-flex align-items-center gap-2">
        <button class="btn btn-primary" @onclick="ImportAsync" disabled="@(string.IsNullOrWhiteSpace(workflowJson))">
            @(publishOnImport ? "Import and publish" : "Import")
        </button>
        <div class="form-check ms-2">
            <input type="checkbox" class="form-check-input" id="publishOnImport" @bind="publishOnImport" />
            <label class="form-check-label" for="publishOnImport">Publish on import</label>
        </div>
    </div>
</section>

<section>
    <div class="d-flex align-items-center justify-content-between mb-3">
        <h2 class="h4 mb-0">Definitions</h2>
        <button class="btn btn-outline-secondary btn-sm" @onclick="LoadAsync">Refresh</button>
    </div>
    @if (workflows is null)
    {
        <p>Loading...</p>
    }
    else if (workflows.Count == 0)
    {
        <p>No workflow definitions found. Import a workflow JSON definition to get started.</p>
    }
    else
    {
        <div class="accordion" id="workflowAccordion">
            @foreach (var workflow in workflows)
            {
                var isExpanded = expandedKeys.Contains(workflow.WorkflowKey);
                <div class="accordion-item">
                    <h2 class="accordion-header">
                        <button class="accordion-button @(isExpanded ? "" : "collapsed")" type="button"
                                @onclick="() => ToggleExpand(workflow.WorkflowKey)">
                            <span class="me-3"><strong>@workflow.Name</strong></span>
                            <span class="badge bg-secondary me-2">v@(workflow.Version)</span>
                            @if (workflow.IsDefault)
                            {
                                <span class="badge bg-primary me-2">Default</span>
                            }
                            @if (workflow.IsPublished)
                            {
                                <span class="badge bg-success">Published</span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark">Unpublished</span>
                            }
                        </button>
                    </h2>
                    @if (isExpanded)
                    {
                        <div class="accordion-body">
                            @if (loadingKeys.Contains(workflow.WorkflowKey))
                            {
                                <p>Loading versions...</p>
                            }
                            else if (!versionsByKey.TryGetValue(workflow.WorkflowKey, out var rows) || rows.Count == 0)
                            {
                                <p class="text-muted">No versions found.</p>
                            }
                            else
                            {
                                <table class="table table-sm">
                                    <thead>
                                        <tr>
                                            <th>Version</th>
                                            <th>Published</th>
                                            <th>Default</th>
                                            <th>Created</th>
                                            <th class="text-end">Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var v in rows)
                                        {
                                            <tr>
                                                <td>v@(v.Version)</td>
                                                <td>
                                                    @if (v.IsPublished)
                                                    {
                                                        <span class="badge bg-success">Yes</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge bg-warning text-dark">No</span>
                                                    }
                                                </td>
                                                <td>
                                                    @if (v.IsDefault)
                                                    {
                                                        <span class="badge bg-primary">Default</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted">-</span>
                                                    }
                                                </td>
                                                <td class="small text-muted">@v.CreatedAt.ToLocalTime().ToString("g")</td>
                                                <td class="text-end">
                                                    @if (v.IsPublished)
                                                    {
                                                        <a class="btn btn-sm btn-outline-primary" href="@($"workflows/{v.Id}/start")">Start</a>
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted small ms-1" title="Publish this version to start instances">Unpublished</span>
                                                    }
                                                    @if (v.IsPublished)
                                                    {
                                                        <button class="btn btn-sm btn-outline-warning ms-1" @onclick="() => UnpublishAsync(v.Id)">Unpublish</button>
                                                    }
                                                    else
                                                    {
                                                        <button class="btn btn-sm btn-outline-success ms-1" @onclick="() => PublishAsync(v.Id)">Publish</button>
                                                    }
                                                    @if (!v.IsDefault)
                                                    {
                                                        <button class="btn btn-sm btn-outline-primary ms-1" @onclick="() => SetDefaultAsync(v.Id)" disabled="@(!v.IsPublished)">Set Default</button>
                                                    }
                                                    <button class="btn btn-sm btn-outline-danger ms-1" @onclick="() => DeleteAsync(v.Id)">Delete</button>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            }
                        </div>
                    }
                </div>
            }
        </div>
    }
</section>

@code {
    private static readonly JsonSerializerOptions JsonOptions = new(JsonSerializerDefaults.Web)
    {
        PropertyNameCaseInsensitive = true
    };

    private IReadOnlyList<WorkflowSummaryDto>? workflows;
    private Dictionary<string, IReadOnlyList<WorkflowSummaryDto>> versionsByKey = new();
    private HashSet<string> expandedKeys = new();
    private HashSet<string> loadingKeys = new();
    private string? workflowJson;
    private string? error;
    private string? fileName;
    private long? fileSize;
    private object inputFileKey = new();
    private bool publishOnImport = true;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        try
        {
            error = null;
            workflows = await Api.GetWorkflowsAsync();
        }
        catch (Exception ex)
        {
            error = ex.Message;
            workflows = [];
        }
    }

    private async Task ToggleExpand(string workflowKey)
    {
        if (expandedKeys.Contains(workflowKey))
        {
            expandedKeys.Remove(workflowKey);
        }
        else
        {
            expandedKeys.Add(workflowKey);
            await LoadVersionsAsync(workflowKey);
        }
    }

    private async Task LoadVersionsAsync(string workflowKey)
    {
        try
        {
            loadingKeys.Add(workflowKey);
            error = null;
            var rows = await Api.GetWorkflowVersionsAsync(workflowKey);
            versionsByKey[workflowKey] = rows;
        }
        catch (Exception ex)
        {
            error = ex.Message;
            versionsByKey[workflowKey] = [];
        }
        finally
        {
            loadingKeys.Remove(workflowKey);
        }
    }

    private async Task OnInputFileChange(InputFileChangeEventArgs e)
    {
        try
        {
            error = null;
            var file = e.File;
            fileName = file.Name;
            fileSize = file.Size;

            // Restrict file size to 2MB (2 * 1024 * 1024 bytes)
            using var stream = file.OpenReadStream(maxAllowedSize: 2 * 1024 * 1024);
            using var reader = new StreamReader(stream);
            workflowJson = await reader.ReadToEndAsync();
        }
        catch (Exception ex)
        {
            error = $"Failed to read file: {ex.Message}";
            workflowJson = null;
            fileName = null;
            fileSize = null;
        }
    }

    private async Task ImportAsync()
    {
        try
        {
            error = null;
            var definition = JsonSerializer.Deserialize<WorkflowModel>(workflowJson ?? string.Empty, JsonOptions)
                ?? throw new InvalidOperationException("Workflow JSON could not be parsed.");
            await Api.CreateWorkflowAsync(new CreateWorkflowRequest(definition, Publish: publishOnImport));
            workflowJson = null;
            fileName = null;
            fileSize = null;
            inputFileKey = new object(); // Resets the InputFile component
            await LoadAsync();
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
    }

    private async Task PublishAsync(long id)
    {
        try
        {
            error = null;
            await Api.PublishWorkflowAsync(id);
            await ReloadVersionsAsync();
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
    }

    private async Task UnpublishAsync(long id)
    {
        try
        {
            error = null;
            await Api.UnpublishWorkflowAsync(id);
            await ReloadVersionsAsync();
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
    }

    private async Task SetDefaultAsync(long id)
    {
        try
        {
            error = null;
            await Api.SetDefaultWorkflowAsync(id);
            await ReloadVersionsAsync();
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
    }

    private async Task DeleteAsync(long id)
    {
        try
        {
            error = null;
            await Api.DeleteWorkflowAsync(id);
            await ReloadVersionsAsync();
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
    }

    private async Task ReloadVersionsAsync()
    {
        await LoadAsync();
        foreach (var key in expandedKeys.ToList())
        {
            await LoadVersionsAsync(key);
        }
    }
}
