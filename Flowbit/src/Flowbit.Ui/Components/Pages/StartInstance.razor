@page "/workflows/{WorkflowId:long}/start"
@using System.Text.Json
@using Flowbit.Ui.Auth
@inject WorkflowApiClient Api
@inject NavigationManager Navigation
@inject TokenState Token

<PageTitle>Start Workflow · Flowbit</PageTitle>

@if (!string.IsNullOrWhiteSpace(error))
{
    <div class="alert alert-danger" role="alert">@error</div>
}

@if (workflow is null)
{
    <PageHeader Eyebrow="Workflows" Title="Start workflow" Description="Loading the selected definition…" />
    <div class="form-surface"><div class="skeleton" role="status"></div></div>
}
else
{
    var startEvents = AllowedStartEvents();
    var selectedNode = startEvents.SingleOrDefault(n => n.Id == selectedStartEventId);

    <PageHeader Eyebrow="New instance" Title="@($"Start {workflow.Name}")"
                Description="@($"Configure the entry point and process values for version {workflow.Version}.")">
        <Actions><a class="btn btn-outline-secondary" href="workflows">Back to workflows</a></Actions>
    </PageHeader>

    @if (startEvents.Count == 0)
    {
        <section class="panel"><EmptyState Icon="alert" Title="Start is not authorized" Description="Your current test identity does not have a role accepted by any user-startable event in this workflow."><a class="btn btn-primary" href="token">Change test identity</a></EmptyState></section>
    }
    else
    {
        <section class="form-surface" aria-labelledby="start-configuration-heading">
            <div class="section-heading">
                <div><h2 id="start-configuration-heading">Start configuration</h2><p>Required values are marked with an asterisk.</p></div>
                <StatusBadge Status="published" Text="@($"Version {workflow.Version}")" />
            </div>

            @if (startEvents.Count > 1)
            {
                <div class="mb-3">
                    <label class="form-label" for="start-event">Start event</label>
                    <select id="start-event" class="form-select" @bind="selectedStartEventId" @bind:after="OnStartEventChanged">
                        @foreach (var startEvent in startEvents)
                        {
                            <option value="@startEvent.Id">@startEvent.Name@(startEvent.Id == workflow.Definition.InitialEventId ? " (default)" : "")</option>
                        }
                    </select>
                </div>
            }
            else if (selectedNode is not null)
            {
                <div class="summary-item mb-3"><span>Start event</span><strong>@selectedNode.Name</strong></div>
            }

            @if (selectedNode is not null && selectedNode.Variables.Count > 0)
            {
                <div class="form-grid">
                    @foreach (var variable in selectedNode.Variables)
                    {
                        var inputId = $"start-variable-{variable.Name.Replace(" ", "-")}";
                        <div class="@(variable.IsArray ? "full" : null)">
                            <label class="form-label" for="@inputId">@variable.Name <span class="field-type">@variable.DataType@(variable.IsArray ? "[]" : "")</span>@if (variable.Required) { <span class="required-mark" aria-label="required"> *</span> }</label>
                            <input id="@inputId" class="form-control" value="@GetInput(variable.Name)" @oninput="e => SetInput(variable.Name, e.Value?.ToString())" placeholder="@InputHint(variable)" />
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="alert alert-info">This start event does not require process variables.</div>
            }

            @if (selectedNode?.Idempotency is not null)
            {
                <div class="mt-3">
                    <label class="form-label" for="idempotency-key">Transport retry key <span class="field-type">@selectedNode.Idempotency.HeaderName</span><span class="required-mark" aria-label="required"> *</span></label>
                    <input id="idempotency-key" class="form-control" @bind="idempotencyKey" autocomplete="off" />
                    <div class="form-text">Retries with this value return the existing instance as a conflict instead of starting another.</div>
                </div>
            }

            <div class="d-flex flex-wrap gap-2 mt-4">
                <button class="btn btn-primary" @onclick="StartAsync" disabled="@submitting"><AppIcon Name="plus" /> @(submitting ? "Starting…" : "Start instance")</button>
                <a class="btn btn-outline-secondary" href="workflows">Cancel</a>
            </div>
        </section>
    }
}

@code {
    [Parameter]
    public long WorkflowId { get; set; }

    private WorkflowDetailDto? workflow;
    private readonly Dictionary<string, string?> inputs = [];
    private int? selectedStartEventId;
    private string? idempotencyKey;
    private string? error;
    private bool submitting;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            error = null;
            workflow = await Api.GetWorkflowAsync(WorkflowId);
            if (workflow is not null)
            {
                var allowedStartEvents = AllowedStartEvents();

                if (allowedStartEvents.Any(e => e.Id == workflow.Definition.InitialEventId))
                {
                    selectedStartEventId = workflow.Definition.InitialEventId;
                }
                else if (allowedStartEvents.Count > 0)
                {
                    selectedStartEventId = allowedStartEvents[0].Id;
                }
                else
                {
                    selectedStartEventId = null;
                }
            }
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
    }

    private List<FlowNodeModel> AllowedStartEvents()
    {
        if (workflow is null)
        {
            return [];
        }

        var userRoles = Token.CurrentRoles ?? [];
        return workflow.Definition.FlowNodes
            .Where(n => BpmnFlowNodeTypes.IsStart(n.Type))
            .Where(n => n.Roles.Count == 0 || n.Roles.Any(r => userRoles.Contains(r, StringComparer.OrdinalIgnoreCase)))
            .ToList();
    }

    private void OnStartEventChanged()
    {
        inputs.Clear();
        idempotencyKey = null;
    }

    private string? GetInput(string name) => inputs.TryGetValue(name, out var value) ? value : null;

    private void SetInput(string name, string? value) => inputs[name] = value;

    private async Task StartAsync()
    {
        if (workflow is null || selectedStartEventId is null)
        {
            return;
        }

        try
        {
            submitting = true;
            error = null;
            var startEvent = workflow.Definition.FlowNodes.Single(n => n.Id == selectedStartEventId);
            var variables = BuildPayload(startEvent.Variables);
            var instance = await Api.StartInstanceAsync(new StartInstanceRequest(
                workflow.Id,
                null,
                selectedStartEventId,
                variables),
                startEvent.Idempotency?.HeaderName,
                idempotencyKey);
            if (instance is not null)
            {
                Navigation.NavigateTo($"/instances/{instance.Id}");
            }
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            submitting = false;
        }
    }

    private static string InputHint(VariableModel variable) => variable.IsArray
        ? "Comma-separated values"
        : variable.DataType switch
        {
            WorkflowVariableTypes.Number => "Enter a number",
            WorkflowVariableTypes.Boolean => "true or false",
            _ => $"Enter {variable.Name}"
        };

    private Dictionary<string, JsonElement> BuildPayload(IEnumerable<VariableModel> variables)
    {
        var payload = new Dictionary<string, JsonElement>();
        foreach (var variable in variables)
        {
            if (!inputs.TryGetValue(variable.Name, out var raw) || string.IsNullOrWhiteSpace(raw))
            {
                continue;
            }

            payload[variable.Name] = ToJsonElement(variable, raw);
        }

        return payload;
    }

    private static JsonElement ToJsonElement(VariableModel variable, string raw)
    {
        if (variable.IsArray)
        {
            var values = raw.Split(',', StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries);
            return JsonSerializer.SerializeToElement(values);
        }

        return variable.DataType switch
        {
            WorkflowVariableTypes.Number when decimal.TryParse(raw, out var number) => JsonSerializer.SerializeToElement(number),
            WorkflowVariableTypes.Boolean when bool.TryParse(raw, out var boolean) => JsonSerializer.SerializeToElement(boolean),
            _ => JsonSerializer.SerializeToElement(raw)
        };
    }
}
