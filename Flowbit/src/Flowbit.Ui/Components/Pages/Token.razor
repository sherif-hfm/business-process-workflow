@page "/token"
@using Flowbit.Ui.Auth
@inject DevTokenFactory TokenFactory
@inject TokenState TokenStore

<PageTitle>Test Identity · Flowbit</PageTitle>

<PageHeader Eyebrow="Developer tools" Title="Test identity"
            Description="Generate or apply a development JWT to test users, roles, claims, and protected workflow functions." />

<div class="alert alert-warning d-flex align-items-start gap-2" role="note">
    <AppIcon Name="alert" Class="mt-1" />
    <div><strong>Development testing only.</strong> This identity is shared by the local UI process and is attached to every API request from Flowbit.Ui.</div>
</div>

@if (!string.IsNullOrWhiteSpace(error))
{
    <div class="alert alert-danger" role="alert">@error</div>
}

<div class="row g-3">
    <div class="col-xl-7">
        <section class="panel h-100" aria-labelledby="generate-token-heading">
            <div class="section-heading">
                <div><h2 id="generate-token-heading">Generate identity</h2><p>Choose a username and the roles you want to exercise.</p></div>
            </div>

            <div class="form-grid">
                <div>
                    <label class="form-label" for="token-user">User</label>
                    <input id="token-user" class="form-control" @bind="user" placeholder="e.g. alice" autocomplete="off" />
                </div>
                <div>
                    <label class="form-label" for="token-expiry">Expires in</label>
                    <div class="input-group">
                        <input id="token-expiry" type="number" class="form-control" @bind="expiresInMinutes" min="1" aria-describedby="token-expiry-unit" />
                        <span id="token-expiry-unit" class="input-group-text">minutes</span>
                    </div>
                </div>
                <div class="full">
                    <label class="form-label" for="token-roles">Roles</label>
                    <input id="token-roles" class="form-control" @bind="roles" placeholder="e.g. Manager, Finance" aria-describedby="role-help" />
                    <div id="role-help" class="form-text">Comma-separated. Role matching in workflow authorization is case-insensitive.</div>
                </div>
                <div class="full">
                    <div class="d-flex flex-wrap gap-2" aria-label="Role suggestions">
                        @foreach (var suggestion in RoleSuggestions)
                        {
                            <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="() => AddRole(suggestion)">+ @suggestion</button>
                        }
                    </div>
                </div>
            </div>

            <div class="mt-4">
                <button class="btn btn-primary" @onclick="Generate"><AppIcon Name="token" /> Generate and apply</button>
            </div>
        </section>
    </div>

    <div class="col-xl-5">
        <section class="panel h-100" aria-labelledby="current-token-heading">
            <div class="section-heading">
                <div><h2 id="current-token-heading">Current identity</h2><p>Identity currently attached to API requests.</p></div>
                <StatusBadge Status="@(TokenStore.HasToken ? "active" : "inactive")" Text="@(TokenStore.HasToken ? "Applied" : "Not set")" />
            </div>

            @if (TokenStore.HasToken)
            {
                <div class="summary-grid mb-3">
                    <div class="summary-item"><span>User</span><strong>@(TokenStore.CurrentUser ?? "anonymous")</strong></div>
                    <div class="summary-item"><span>Roles</span><strong>@(TokenStore.CurrentRoles.Count == 0 ? "None" : string.Join(", ", TokenStore.CurrentRoles))</strong></div>
                </div>
            }
            else
            {
                <div class="alert alert-info">No token is set. Protected API requests will return 401 until you apply an identity.</div>
            }

            <label class="form-label" for="raw-token">Raw JWT</label>
            <textarea id="raw-token" class="form-control font-monospace" rows="7" @bind="rawToken" spellcheck="false"
                      placeholder="Paste a JWT to test it as-is, including invalid or expired tokens."></textarea>
            <div class="d-flex flex-wrap gap-2 mt-3">
                <button class="btn btn-outline-primary" @onclick="ApplyRaw">Apply pasted token</button>
                <button class="btn btn-outline-danger" @onclick="Clear" disabled="@(!TokenStore.HasToken && string.IsNullOrWhiteSpace(rawToken))">Clear identity</button>
            </div>
        </section>
    </div>
</div>

@code {
    private static readonly string[] RoleSuggestions = ["User", "Manager", "Reviewer", "Finance", "sysAdmin", "admin"];

    private string user = "alice";
    private string roles = string.Empty;
    private int expiresInMinutes = 60;
    private string rawToken = string.Empty;
    private string? error;

    protected override void OnInitialized() => rawToken = TokenStore.Token ?? string.Empty;

    private void AddRole(string role)
    {
        var current = roles
            .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .ToList();
        if (!current.Contains(role, StringComparer.OrdinalIgnoreCase))
        {
            current.Add(role);
        }

        roles = string.Join(", ", current);
    }

    private void Generate()
    {
        try
        {
            error = null;
            var roleList = roles
                .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
            var token = TokenFactory.Create(user, roleList, expiresInMinutes);
            TokenStore.Set(token);
            rawToken = token;
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
    }

    private void ApplyRaw()
    {
        error = null;
        TokenStore.Set(rawToken);
    }

    private void Clear()
    {
        error = null;
        TokenStore.Clear();
        rawToken = string.Empty;
    }
}
