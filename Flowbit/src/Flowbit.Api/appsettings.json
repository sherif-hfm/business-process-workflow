{
  "ConnectionStrings": {
    "Flowbit": "Host=localhost;Port=5432;Database=workflow_engine;Username=postgres;Password=P@ssw0rd"
  },
  "Jwt": {
    "Issuer": "workflow-engine-dev",
    "Audience": "workflow-engine-api",
    "Key": "dev-only-symmetric-signing-key-change-me-please-32+"
  },
  "WorkflowServiceTasks": {
    "MaxTimeoutSeconds": 300,
    "MaxResponseBodyBytes": 1048576
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/flowbit-api-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "AllowedHosts": "*"
}
